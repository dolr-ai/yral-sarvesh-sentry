# ============================================================================
# yral-sarvesh-sentry — single source of truth for version + placement config
# ============================================================================
#
# This file is the one place where all environment-specific and version-
# specific values live. Every other config file in this repo reads from this
# one (via `set -a; source project.config; set +a` in install scripts, or via
# GitHub Actions env inputs in CI).
#
# WHY a single config file? Same reason the infra template does it — you edit
# ONE file to rename, upgrade, or relocate the service, and every shell script
# + CI workflow + Caddy snippet + systemd unit picks up the new value. No more
# sed-across-50-files. This matches the "project.config as SSOT" pattern from
# yral-sarvesh-hetzner-infra-template.
#
# HOW to use: never read an environment variable directly from a shell script
# in scripts/ — read this file instead. If a new setting is needed, add it
# here first and update the consuming script to reference it.
#
# SAFETY: do NOT put any secret in this file. This file is committed to git.
# Secrets (OAuth client secret, SMTP password, superuser bootstrap password)
# live in GitHub Secrets or in `docker compose`'s per-container env files,
# never here. See SECURITY.md (to be written in Phase 9).
# ============================================================================

# --- Identity ----------------------------------------------------------------

# Name of this service. Used for Docker Compose project name + backup paths
# on S3 (s3://sarvesh-yral/yral-sarvesh-sentry/daily/...) + Caddy snippet filename
# (/home/yral-deploy/caddy/conf.d/yral-sarvesh-sentry.caddy).
PROJECT_NAME=yral-sarvesh-sentry

# Public URL where users hit Sentry in a browser. Set in Sentry's config.yml
# under `system.url-prefix`. Also drives Google OAuth redirect URI and the
# Caddy snippet hostname.
PROJECT_DOMAIN=sentry.sarvesh.yral.com

# --- Sentry upstream pin -----------------------------------------------------

# Exact tag from https://github.com/getsentry/self-hosted/releases.
# WHY PIN? Sentry's upstream `master` branch can ship breaking schema changes
# on any day. By pinning to a release tag, our cluster only upgrades when
# WE choose to — `scripts/upgrade.sh` is the only thing that changes this.
#
# Chosen tag: 26.6.0 (published 2026-04-16, latest stable at time of install).
# To upgrade: read the upstream CHANGELOG for every release between the
# current pin and the target, then bump this and run scripts/upgrade.sh.
SENTRY_VERSION=26.6.0

# Local clone path on sarvesh-3. The upstream repo gets cloned here and pinned
# to SENTRY_VERSION. We do NOT modify files inside this clone; all our
# overrides live in our own repo and get mounted / merged at runtime.
#
# WHY under /home/yral-deploy and not /opt? /opt is the Unix convention for
# system-installed software and requires root (sudo) to write. The `yral-deploy`
# user on sarvesh-3 runs Docker directly and does NOT have passwordless sudo
# (confirmed 2026-04-21). Keeping the clone in the yral-deploy user's home
# directory means the entire install script runs without sudo prompts,
# which matters a lot for a 20–40 minute non-interactive install. The
# data ownership is identical either way — yral-deploy is the only service
# account that runs Sentry anyway.
SENTRY_UPSTREAM_DIR=/home/yral-deploy/sentry-upstream

# --- Placement --------------------------------------------------------------

# Where Sentry runs. Decision recorded in the plan + PRE-FLIGHT.md:
# sarvesh-3 has 61 GB free RAM / 857 GB free disk / load < 0.4 — plenty of
# room to colocate with existing etcd + Patroni followers.
#
# WHY no IP here? This repo is public. We don't advertise "this IP runs
# our Sentry" in cleartext — weak recon-enablement for zero benefit. The
# real IP lives in a GitHub Secret named `SENTRY_HOST_IP`, which CI jobs
# and operational scripts read at runtime. Local development uses
# `scripts/load-env.sh` (to be added in Phase 2) which fetches the same
# value from `gh secret` or from `~/.config/dolr-ai/sentry-host-ip`.
SENTRY_HOST=sarvesh-3

# Port on the host where Sentry's internal nginx listens. We bind this to
# 127.0.0.1 (loopback) — NOT 0.0.0.0 — so Sentry is NOT reachable from the
# public internet directly. Caddy on sarvesh-1 + sarvesh-2 is the only thing
# that can reach it, over the Docker Swarm `web` overlay network or a
# private IP route. See Phase 3 of the plan for connectivity decision.
SENTRY_BIND_ADDRESS=127.0.0.1
SENTRY_PORT=9000

# --- Resource limits ---------------------------------------------------------
#
# Applied via docker-compose.override.yml so Sentry can't starve the Patroni
# follower or etcd node living on the same host.
#
# Starting values chosen conservatively for a small team (~5 users, < 100
# events/min). Raise if the health check starts flapping or Sentry reports
# dropped events. See RUNBOOK.md for tuning guidance (Phase 9).

SENTRY_WEB_MEM=2g
SENTRY_WORKER_MEM=3g
SENTRY_SNUBA_MEM=4g
SENTRY_CLICKHOUSE_MEM=4g
SENTRY_KAFKA_MEM=2g
SENTRY_RELAY_MEM=512m
SENTRY_POSTGRES_MEM=2g
SENTRY_REDIS_MEM=512m

# --- Backup target -----------------------------------------------------------
#
# Same Hetzner Object Storage bucket as every other service, with a unique
# per-service prefix. Credentials live ONLY in this repo's GitHub Secrets
# as BACKUP_S3_ACCESS_KEY + BACKUP_S3_SECRET_KEY (the shared dolr-ai creds).
# See reference_hetzner_object_storage.md in Sarvesh's memory.
BACKUP_S3_ENDPOINT=https://hel1.your-objectstorage.com
BACKUP_S3_BUCKET=sarvesh-yral
BACKUP_S3_PREFIX=yral-sarvesh-sentry

# How long to keep daily pg_dumps of Sentry's Postgres. Clickhouse events
# themselves have their own retention inside Sentry (default 90 days).
BACKUP_DAILY_RETENTION=7
BACKUP_WEEKLY_RETENTION=4
